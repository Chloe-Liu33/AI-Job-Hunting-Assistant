# ---- Pick ONE provider ----
# Gemini Flash (recommended). Get a free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Groq (alternative, very fast). Get a free key: https://console.groq.com/keys
# GROQ_API_KEY=

# ---- Provider selection ----
# "gemini" or "groq". If left blank, the app auto-detects from whichever key is set.
LLM_PROVIDER=

# ---- Models (sensible defaults; change only if you want) ----
# Gemini model name
GEMINI_MODEL=gemini-2.0-flash
# Groq model name
GROQ_MODEL=llama-3.3-70b-versatile

# ---- Embeddings (local, CPU) ----
# English-only (small & fast):      sentence-transformers/all-MiniLM-L6-v2
# Multilingual (EN + 中文, etc.):    intfloat/multilingual-e5-small
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ---- Persistent data location (file backend) ----
# Where the app WRITES runtime data (accounts, per-user CVs/JDs, indexes,
# traces) in the DEFAULT file/FAISS backend. Leave blank to use the repo's
# data/ folder. On a host with a persistent disk (e.g. Hugging Face persistent
# storage), point this at the mounted path so data survives restarts:
# DATA_DIR=/data

# ---- External vector DB backend (recommended for permanent storage) ----
# Set QDRANT_URL to switch accounts + CVs/JDs + embeddings to an external Qdrant
# vector database (free managed tier at https://cloud.qdrant.io). When unset,
# the app uses the local file/FAISS backend above. Per-user isolation is
# enforced by a user_id filter on every query.
# QDRANT_URL=https://YOUR-CLUSTER.cloud.qdrant.io:6333
# QDRANT_API_KEY=

# ---- Agent / framework extras ----
# The Agent tab (LangChain), LlamaIndex, OpenAI Agents SDK and the prompt
# benchmark reuse the SAME keys above — no extra secrets needed. They just need
# the optional packages: pip install -r requirements-extras.txt
# Note: the OpenAI Agents SDK path runs on Groq's OpenAI-compatible endpoint,
# so it works with GROQ_API_KEY (no paid OpenAI account required).
